# ── Server-side (Vercel env vars — set in Vercel Dashboard, NOT in .env) ──
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=your-service-role-key
# ONESIGNAL_APP_ID=your-onesignal-app-id
# ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key
# WEBHOOK_SECRET=your-webhook-secret
# GEMINI_API_KEY=your-gemini-api-key  (also needed in .env for local dev of api/chat.js)
# GROQ_API_KEY=your-groq-api-key  (free at https://console.groq.com — 14K req/day)

